{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hamza-lhamza-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://hamza-lhamza-backend-production.up.railway.app/media/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
